1，一个 完整的 cache locality 实验程序。该程序对比三种访问模式：
    顺序访问（sequential）
    stride 访问（跳跃访问）
    随机访问（random）
    运行后可以用 perf 观察 cache miss、IPC、cycles 的差异

        #include <stdio.h>
        #include <stdlib.h>
        #include <time.h>
        #define SIZE (256*1024*1024)   // 256MB
        #define STRIDE 16
        
        int *arr;
        void sequential()
        {
            long long sum = 0;
        
            for(long i = 0; i < SIZE; i++)
                sum += arr[i];
        
            printf("seq sum: %lld\n", sum);
        }
        
        void stride_access()
        {
            long long sum = 0;
        
            for(long i = 0; i < SIZE; i += STRIDE)
                sum += arr[i];
        
            printf("stride sum: %lld\n", sum);
        }
        
        void random_access()
        {
            long long sum = 0;
        
            for(long i = 0; i < SIZE; i++)
            {
                long idx = rand() % SIZE;
                sum += arr[idx];
            }
        
            printf("rand sum: %lld\n", sum);
        }
        
        int main()
        {
            arr = malloc(sizeof(int) * SIZE);
        
            for(long i = 0; i < SIZE; i++)
                arr[i] = i;
        
            srand(time(NULL));
        
            sequential();
            stride_access();
            random_access();
        
            free(arr);
        }

