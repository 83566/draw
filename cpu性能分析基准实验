        void* worker(void* arg) {
            int id = *(int*)arg;
            for (long i = 0; i < ITER; i++) {
                //counter[id].value++;   // 每个线程修改不同元素
        		 counter[id]++;
            }
            return NULL;
        }
        
        int main() {
            pthread_t t[THREADS];
            int id[THREADS];
        
            for (int i = 0; i < THREADS; i++) {
